# Prism QA Backend — Environment Variables
# Copy this file to .env and fill in your values.

# Google GenAI API Key (required for visual analysis in Phase 2+)
GOOGLE_GENAI_API_KEY=

# Server configuration
PORT=3001

# WebSocket allowed origin (set to your frontend URL, e.g. http://localhost:3000)
ALLOWED_ORIGIN=http://localhost:3000

# WebSocket auth: clients must send ?token=<this value>; set same value as NEXT_PUBLIC_WS_TOKEN in frontend
WS_SECRET_TOKEN=

# Playwright browser settings
# Use 'headless' for production, 'headed' to watch the browser during development
PLAYWRIGHT_HEADLESS=true
