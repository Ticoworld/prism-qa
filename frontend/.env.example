# Prism QA Frontend — Environment Variables
# Copy to .env.local (or .env) and fill in. For local dev, NEXT_PUBLIC_WS_TOKEN must match backend WS_SECRET_TOKEN.

# Backend WebSocket URL. Leave empty for local default (ws://localhost:3001/ws).
# Production: set to your Cloud Run WS URL, e.g. wss://prism-qa-backend-xxx.run.app/ws
NEXT_PUBLIC_WS_URL=

# WebSocket auth token. Must match backend WS_SECRET_TOKEN for connections to succeed.
NEXT_PUBLIC_WS_TOKEN=
